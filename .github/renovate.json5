{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>junit-team/renovate-config',
  ],
  packageRules: [
    {
      "matchPackageNames": [
        "com.gradleup.nmcp:*",
      ],
      "allowedVersions": "<1.6.0", // due to https://github.com/GradleUp/nmcp/issues/262
    },
  ],
}
